---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const resources = (await getCollection('resources')).sort((a, b) => a.data.order - b.data.order);
---
<BaseLayout title="Resources — Frazier Smith" description="Free study materials, templates, and tools for students and educators, published by Dr. Frazier A. Smith." current="resources">
  <header class="page-header">
    <div class="container">
      <span class="kicker">Resources</span>
      <h1>Things I've made public.</h1>
      <p class="lede">Study materials, templates, and tools — free to use, adapt, and fork.</p>
    </div>
  </header>

  <section class="container list-wrap">
    {resources.length > 0 ? (
      <div class="grid">
        {resources.map((r) => (
          <a class="card" href={r.data.url} rel="noopener" target="_blank">
            <span class="kind">{r.data.kind}</span>
            <h3>{r.data.title}</h3>
            <p>{r.data.description}</p>
            {r.data.audience && <span class="audience">For: {r.data.audience}</span>}
            <span class="link">View resource →</span>
          </a>
        ))}
      </div>
    ) : (
      <p class="empty">Nothing published here yet — check back soon.</p>
    )}
  </section>
</BaseLayout>

<style>
  .container { max-width: var(--container-max); margin: 0 auto; padding-left: var(--space-page-x); padding-right: var(--space-page-x); }
  .page-header { padding: 70px 0 40px; border-bottom: 2px solid var(--ink); }
  .kicker { font-size: 11px; letter-spacing: .15em; text-transform: uppercase; font-weight: 800; background: var(--ink); color: var(--page); padding: 4px 10px; border-radius: 4px; }
  h1 { font-size: 60px; line-height: 1; margin: 18px 0 18px; font-weight: 800; letter-spacing: -.035em; }
  .lede { font-size: 17px; line-height: 1.55; max-width: 70ch; color: var(--ink-2); }
  .list-wrap { padding: 50px 0 80px; }

  .grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; }
  .card {
    display: block;
    background: var(--card);
    border: 2px solid var(--ink);
    border-radius: var(--radius-lg);
    padding: 24px;
    box-shadow: var(--shadow-card);
    color: var(--ink);
  }
  .card:hover { transform: translate(-1px, -1px); box-shadow: 5px 5px 0 var(--ink); transition: transform .12s, box-shadow .12s; }
  .kind {
    display: inline-block;
    font-size: 10px;
    letter-spacing: .12em;
    text-transform: uppercase;
    margin-bottom: 12px;
    font-weight: 800;
    color: var(--accent);
  }
  h3 { font-size: 19px; margin: 0 0 10px; font-weight: 800; line-height: 1.2; letter-spacing: -.015em; }
  p { font-size: 14px; line-height: 1.55; margin: 0 0 12px; color: var(--ink-2); }
  .audience { display: block; font-size: 12px; color: var(--muted); font-weight: 600; margin-bottom: 12px; }
  .link { font-size: 13px; font-weight: 700; color: var(--accent); }

  .empty { padding: 32px 24px; background: var(--card); border: 2px dashed var(--ink); border-radius: var(--radius-lg); text-align: center; color: var(--muted); }

  @media (max-width: 720px) {
    h1 { font-size: 40px; }
    .grid { grid-template-columns: 1fr; }
  }
</style>
