---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { education, certifications, awards, service } from '../data/credentials';

const career = (await getCollection('career')).sort((a, b) => a.data.order - b.data.order);
const courses = await getCollection('courses');
const speakingTopics = (await getCollection('speakingTopics')).sort((a, b) => a.data.order - b.data.order);
const talks = (await getCollection('talksGiven')).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const posts = (await getCollection('posts', ({ data }) => !data.draft)).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const groupedCourses = courses.reduce<Record<string, typeof courses>>((acc, c) => {
  (acc[c.data.institution] ||= []).push(c);
  return acc;
}, {});
const institutionsOrder = ['Central Piedmont', 'UNC Charlotte', 'Wingate', 'Wake Tech', 'Wayne CC'];

const currentRoles = [
  { years: 'July 2025 – present', title: 'Department Chair, Network Management, Cybersecurity, and Cloud & Virtualization', org: 'Central Piedmont Community College', areas: ['Cybersecurity', 'Cloud & Networking', 'IT Support'] },
  { years: 'March 2023 – present', title: 'Instructor, Network Management, Cybersecurity, and Cloud & Virtualization', org: 'Central Piedmont Community College' },
  { years: 'October 2025 – present', title: 'Associate Graduate Faculty', org: 'UNC Charlotte — School of Data Science & College of Computing and Informatics' },
  { years: 'January 2026 – present', title: 'Adjunct Instructor, Honors Program', org: 'Wingate University' },
];

const languages = ['English (native)', 'Spanish (limited working)'];

function fmtDate(d: Date) {
  return d.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
}
---
<BaseLayout title="CV — Dr. Frazier A. Smith" description="Full curriculum vitae for Dr. Frazier A. Smith — AI & IT educator, NSF co-PI, department chair at Central Piedmont." current="">
  <article class="cv">
    <header class="cv-header">
      <div class="hgroup">
        <h1>Dr. Frazier A. Smith</h1>
        <p class="title">AI &amp; IT Educator · Learning Design Leader · Community College Leadership</p>
        <p class="meta">
          Charlotte, NC · <a href="mailto:frazier@vfrazier.app">frazier@vfrazier.app</a> ·
          <a href="https://vfrazier.app" rel="noopener">vfrazier.app</a> ·
          <a href="https://linkedin.com/in/fraziersmith" rel="noopener">linkedin.com/in/fraziersmith</a>
        </p>
      </div>
      <div class="actions">
        <a href="/cv.pdf" class="pdf">Download PDF →</a>
      </div>
    </header>

    <section>
      <h2>Current roles</h2>
      <ul class="entries">
        {currentRoles.map((r) => (
          <li>
            <span class="years">{r.years}</span>
            <div>
              <div class="role">{r.title}</div>
              <div class="org">{r.org}</div>
              {r.areas && (
                <div class="areas">Program areas: {r.areas.map((a, i) => (<>{i > 0 && ' · '}<span class="area">{a}</span></>))}</div>
              )}
            </div>
          </li>
        ))}
      </ul>
    </section>

    <section>
      <h2>Research focus</h2>
      <p class="prose">The application of artificial intelligence in career-development programs, and the effectiveness of post-secondary career and technical education in preparing students for industry — specifically, how generative AI is reshaping entry-level IT roles, and what community-college curriculum must change in response.</p>
    </section>

    <section>
      <h2>Sponsored research</h2>
      <ul class="entries">
        <li>
          <span class="years">July 2025 – July 2028</span>
          <div>
            <div class="role">Co-Principal Investigator, Generating AI Talent (GAIT)</div>
            <div class="org">NSF Advanced Technological Education · Award #2500901 · $454,000 · PI: Dr. Carl Arrington, Central Piedmont Community College</div>
            <p class="entry-note">Coordinates faculty development, leads course redesign for the core AI curriculum, and directs community AI outreach. Building one of NC’s first associate-degree AI programs.</p>
          </div>
        </li>
      </ul>
    </section>

    <section>
      <h2>Grants under review</h2>
      <ul class="entries">
        <li>
          <span class="years">Under review</span>
          <div>
            <div class="role">Principal Investigator, ASPIRE-IT</div>
            <div class="org">NSF S-STEM · Track 1 · $2,000,000 requested</div>
          </div>
        </li>
      </ul>
    </section>

    <section>
      <h2>Education</h2>
      <ul class="entries">
        {education.map((e) => (
          <li>
            <span class="years">{e.date}</span>
            <div>
              <div class="role">{e.deg}</div>
              <div class="org">{e.inst}</div>
              {e.honors && <div class="honors">{e.honors}</div>}
            </div>
          </li>
        ))}
      </ul>
    </section>

    <section>
      <h2>Certifications</h2>
      <ul class="bullets">
        {certifications.map((c) => <li>{c}</li>)}
      </ul>
    </section>

    <section>
      <h2>Career history</h2>
      <ul class="entries">
        {career.map((c) => (
          <li>
            <span class="years">{c.data.years}</span>
            <div>
              <div class="role">{c.data.title}</div>
              <div class="org">{c.data.org}</div>
            </div>
          </li>
        ))}
      </ul>
    </section>

    <section>
      <h2>Teaching</h2>
      {institutionsOrder.map((inst) => groupedCourses[inst] && (
        <div class="teach-block">
          <h3>{inst}</h3>
          <ul class="bullets compact">
            {groupedCourses[inst].map((c) => (
              <li>
                <span class="code">{/\d/.test(c.data.code) ? c.data.code : c.data.level}</span>
                {' · '}{c.data.title}
                {c.data.current && <span class="pill">Currently teaching</span>}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </section>

    <section>
      <h2>Curriculum development</h2>
      <ul class="dev-list">
        <li>
          <div class="dev-title">Five IT degree concentrations <span class="dev-meta">Effective Fall 2026</span></div>
          <p>Redesigned and launched Cybersecurity, Cloud &amp; Networking Technologies, Data Analytics, Software Engineering, and IT Support. Produced degree information sheets, advisor guides, and student-facing materials for each.</p>
        </li>
        <li>
          <div class="dev-title">NOS 220 · Linux/UNIX Administration II</div>
          <p>Designed as an asynchronous course aligned to Red Hat RH134 objectives.</p>
        </li>
        <li>
          <div class="dev-title">CSC 214 · Artificial Intelligence II</div>
          <p>Designed and aligned to Microsoft Azure AI-102 certification objectives.</p>
        </li>
        <li>
          <div class="dev-title">Digital Wellness &amp; AI</div>
          <p>Honors course designed for Wingate University.</p>
        </li>
        <li>
          <div class="dev-title">“Would You Pull the Lever?”</div>
          <p>AI ethics workshop developed under NSF ATE award #2500901.</p>
        </li>
        <li>
          <div class="dev-title">xAPI learning-record system</div>
          <p>Built and deployed to support hands-on cybersecurity lab instruction.</p>
        </li>
      </ul>
    </section>

    <section>
      <h2>Published curriculum materials</h2>
      <ul class="dev-list">
        <li>
          <div class="dev-title">Introduction to Web Development <span class="dev-meta">Course Author · Sophia Learning</span></div>
          <p><a href="https://www.sophia.org/online-courses/computer-science-and-it/introduction-to-web-development/" rel="noopener">sophia.org/online-courses — Introduction to Web Development</a></p>
        </li>
        <li>
          <div class="dev-title">Introduction to Networking <span class="dev-meta">Assessment Author · Sophia Learning</span></div>
          <p><a href="https://www.sophia.org/online-courses/computer-science-and-it/introduction-to-networking/" rel="noopener">sophia.org/online-courses — Introduction to Networking</a></p>
        </li>
        <li>
          <div class="dev-title">Introduction to Cybersecurity <span class="dev-meta">Course Author · Sophia Learning · Upcoming</span></div>
        </li>
        <li>
          <div class="dev-title">CSC 214 · Artificial Intelligence II <span class="dev-meta">Course Author · OER</span></div>
          <p>Open educational resource published under NSF ATE award #2500901. <a href="https://frazier-at-cpcc.github.io/csc214-oer" rel="noopener">View the OER →</a></p>
        </li>
        <li>
          <div class="dev-title">VMware Cloud on AWS 2024 <span class="dev-meta">Virtual instructor-led training</span></div>
          <p>40-hour on-demand video training course.</p>
        </li>
        <li>
          <div class="dev-title">VMware HCX 2024 <span class="dev-meta">Virtual instructor-led training</span></div>
          <p>40-hour training course.</p>
        </li>
        <li>
          <div class="dev-title">VMware vSphere: Install, Configure, Manage v8 <span class="dev-meta">Content Manager</span></div>
        </li>
        <li>
          <div class="dev-title">VMware vSphere: Operate, Scale, Secure v8 <span class="dev-meta">Content Manager</span></div>
        </li>
      </ul>
    </section>

    <section>
      <h2>Speaking topics</h2>
      <p class="prose">Eight talks regularly delivered in keynote, panel, and workshop formats. See <a href="/speaking">/speaking</a> for full abstracts.</p>
      <ul class="bullets compact">
        {speakingTopics.map((t) => (
          <li>
            {t.data.title}{t.data.nsfFunded && <span class="pill nsf">NSF</span>}
            <span class="tag">— {t.data.tag}</span>
          </li>
        ))}
      </ul>
    </section>

    {talks.length > 0 && (
      <section>
        <h2>Recent talks</h2>
        <ul class="entries">
          {talks.map((t) => (
            <li>
              <span class="years">{fmtDate(t.data.date)}</span>
              <div>
                <div class="role">{t.data.talkTitle} <span class="fmt-pill">{t.data.format}</span></div>
                <div class="org">{t.data.event}{t.data.location && <> · {t.data.location}</>}</div>
              </div>
            </li>
          ))}
        </ul>
      </section>
    )}

    {posts.length > 0 && (
      <section>
        <h2>Writing</h2>
        <ul class="bullets compact">
          {posts.map((p) => (
            <li>
              <a href={`/writing/${p.id}`}>{p.data.title}</a>
              <span class="tag"> — {p.data.category}, {p.data.pubDate.toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}</span>
            </li>
          ))}
        </ul>
      </section>
    )}

    <section>
      <h2>Honors &amp; awards</h2>
      <ul class="bullets">
        {awards.map((a) => <li>{a}</li>)}
      </ul>
    </section>

    <section>
      <h2>Service</h2>
      <ul class="entries">
        {service.map((s) => (
          <li>
            <span class="years">{s.years}</span>
            <div><div class="role">{s.body}{s.detail && <> — {s.detail}.</>}</div></div>
          </li>
        ))}
      </ul>
    </section>

    <section class="last">
      <h2>Languages</h2>
      <ul class="bullets">
        {languages.map((l) => <li>{l}</li>)}
      </ul>
    </section>

    <footer class="cv-footer">
      <p>Last updated {new Date().toLocaleDateString('en-US', { month: 'long', year: 'numeric' })}. A printable PDF is available at <a href="/cv.pdf">/cv.pdf</a>.</p>
    </footer>
  </article>
</BaseLayout>

<style>
  .cv {
    max-width: 880px;
    margin: 0 auto;
    padding: 60px var(--space-page-x) 80px;
  }
  .cv-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 24px;
    padding-bottom: 22px;
    border-bottom: 2px solid var(--ink);
    margin-bottom: 32px;
  }
  .cv-header h1 {
    font-size: 40px;
    font-weight: 800;
    letter-spacing: -.025em;
    line-height: 1.05;
    margin: 0 0 6px;
  }
  .cv-header .title {
    font-size: 14px;
    color: var(--ink-2);
    font-weight: 700;
    margin: 0 0 8px;
  }
  .cv-header .meta {
    font-size: 13px;
    color: var(--muted);
    font-weight: 500;
    margin: 0;
  }
  .cv-header .meta a { color: var(--accent); text-decoration: underline; }
  .pdf {
    background: var(--ink);
    color: var(--page);
    padding: 10px 16px;
    border-radius: var(--radius-pill);
    font-size: 12px;
    font-weight: 700;
    display: inline-block;
    white-space: nowrap;
  }

  section { margin-bottom: 30px; }
  section.last { margin-bottom: 0; }
  section h2 {
    font-size: 12px;
    letter-spacing: .15em;
    text-transform: uppercase;
    font-weight: 800;
    color: var(--accent);
    border-bottom: 1.5px solid var(--ink);
    padding-bottom: 6px;
    margin-bottom: 14px;
  }
  section h3 {
    font-size: 14px;
    font-weight: 800;
    color: var(--ink);
    margin: 16px 0 6px;
  }

  .prose { font-size: 14px; line-height: 1.6; color: var(--ink-2); max-width: 72ch; }
  .prose a { color: var(--accent); }

  .entries { list-style: none; display: grid; gap: 10px; }
  .entries li {
    display: grid;
    grid-template-columns: max-content 1fr;
    gap: 16px;
    align-items: baseline;
    font-size: 14px;
  }
  .entries .years {
    font-weight: 800;
    color: var(--ink);
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }
  .entries .role { font-weight: 600; color: var(--ink); line-height: 1.35; }
  .entries .org { color: var(--muted); font-size: 13px; margin-top: 2px; }
  .entries .areas { font-size: 13px; margin-top: 4px; color: var(--ink-2); font-weight: 600; }
  .entries .area { display: inline-block; }
  .entries .honors { font-size: 13px; margin-top: 2px; color: var(--accent); font-weight: 700; }
  .entry-note { font-size: 13px; line-height: 1.5; color: var(--ink-2); margin: 6px 0 0; max-width: 68ch; }

  .dev-list { list-style: none; display: grid; gap: 12px; padding: 0; }
  .dev-list li { border-left: 2.5px solid var(--accent); padding-left: 14px; }
  .dev-list .dev-title { font-size: 14px; font-weight: 700; color: var(--ink); }
  .dev-list .dev-meta { font-size: 11px; font-weight: 700; color: var(--muted); text-transform: uppercase; letter-spacing: .06em; margin-left: 6px; }
  .dev-list p { font-size: 13px; line-height: 1.5; color: var(--ink-2); margin: 3px 0 0; max-width: 68ch; }
  .dev-list a { color: var(--accent); text-decoration: underline; text-underline-offset: 2px; word-break: break-word; }

  .bullets { list-style: none; padding-left: 16px; }
  .bullets li { font-size: 14px; line-height: 1.5; margin-bottom: 5px; position: relative; }
  .bullets li::before { content: '✦'; color: var(--accent); position: absolute; left: -16px; }
  .bullets.compact li { font-size: 13px; margin-bottom: 4px; }
  .bullets .code { font-weight: 800; letter-spacing: -.01em; }
  .bullets a { color: var(--ink); text-decoration: underline; text-decoration-color: var(--accent); text-underline-offset: 3px; }
  .bullets .tag { color: var(--muted); font-size: 12px; font-weight: 500; }

  .pill {
    display: inline-block;
    margin-left: 8px;
    background: var(--accent);
    color: var(--page);
    font-size: 9px;
    font-weight: 800;
    padding: 2px 7px;
    border-radius: var(--radius-pill);
    letter-spacing: .08em;
    text-transform: uppercase;
    vertical-align: middle;
  }
  .pill.nsf { background: var(--ink); color: var(--highlight); }

  .fmt-pill {
    display: inline-block;
    margin-left: 6px;
    background: var(--page);
    color: var(--ink);
    border: 1.5px solid var(--ink);
    font-size: 9px;
    font-weight: 800;
    padding: 1px 6px;
    border-radius: 3px;
    letter-spacing: .08em;
    text-transform: uppercase;
    vertical-align: middle;
  }

  .teach-block { margin-bottom: 14px; }

  .cv-footer {
    margin-top: 50px;
    padding-top: 18px;
    border-top: 1.5px solid var(--ink);
    font-size: 12px;
    color: var(--muted);
  }
  .cv-footer a { color: var(--accent); text-decoration: underline; }

  @media (max-width: 720px) {
    .cv-header { flex-direction: column; align-items: flex-start; }
    .cv-header h1 { font-size: 30px; }
    .entries li { grid-template-columns: 1fr; gap: 2px; }
    .entries .years { font-size: 12px; color: var(--muted); }
  }

  @media print {
    body { background: white; }
    .cv { padding: 24px 32px; max-width: 100%; }
    .pdf { display: none !important; }
    /* Site chrome lives in separate components, so these selectors must be
       :global() to escape Astro's per-component style scoping — otherwise the
       nav, POV bar, and footer bleed into the printed CV / generated PDF. */
    :global(nav.nav),
    :global(aside.pov),
    :global(footer.footer),
    :global(.skip-link) { display: none !important; }
    section { page-break-inside: avoid; }
    .cv-header { padding-bottom: 14px; margin-bottom: 18px; }
  }
</style>
