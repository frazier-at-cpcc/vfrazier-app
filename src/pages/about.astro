---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import HighlightPhrase from '../components/HighlightPhrase.astro';
import headshot from '../assets/headshot.jpg';
import { education, certifications } from '../data/credentials';

const career = (await getCollection('career')).sort((a, b) => a.data.order - b.data.order);

const awards = [
  'Worldwide Training Delivery Impact Award',
  'Worldwide Sales and Strategy Acceleration Quarterly Award — Accelerator',
  'Team Member Excellence Award',
  'Best of Show — DevLearn DemoFest',
];
const service = [
  { years: '2025 – 2028', body: 'Faculty Senator, Central Piedmont Community College' },
  { years: '2025 – present', body: 'Curriculum Committee, Central Piedmont Community College' },
  { years: '2026 – 2027', body: 'Faculty Readiness Chair, Canvas Implementation Taskforce, Central Piedmont' },
  { years: '2025 – present', body: 'Co-PI, NSF ATE Generating AI Talent (GAIT) grant' },
  { years: '2017 – present', body: 'Advisory Board, Highland School of Technology (Gastonia, NC)' },
];
---
<BaseLayout title="About — Frazier Smith" current="about">
  <header class="page-header">
    <div class="container hdr">
      <div>
        <span class="kicker">About</span>
        <h1>Music classroom to AI lab.</h1>
        <p class="lede">I lead the Network, Cybersecurity, and Cloud department at Central Piedmont; serve as graduate faculty at UNC Charlotte; teach Applied Innovation in Wingate's Honors program; and co-PI an NSF ATE grant building one of NC's first associate-degree AI programs.</p>
        <div class="cv-row">
          <a href="/cv" class="cv-btn primary">View CV →</a>
          <a href="/cv.pdf" class="cv-btn ghost">Download PDF</a>
        </div>
      </div>
      <div class="photo">
        <Image src={headshot} alt="Dr. Frazier A. Smith" widths={[280, 420, 560]} sizes="(max-width: 720px) 220px, 320px" />
      </div>
    </div>
  </header>

  <section class="container section">
    <h2>Classroom → Enterprise → Classroom</h2>
    <p>Through college at Wingate — where I majored in music education — I served as the campus Educational Technology Specialist. After graduating in 2014, my first post-college role was on Belk's eLearning team. That kicked off a decade in enterprise instructional design and technical training, with stops at CPI Security, SnapAV, Anomali, Carbon Black, VMware, Broadcom, and Fast Lane. The work was always teaching — just teaching working engineers instead of students.</p>
    <p>I came back to higher ed in 2023 by adjuncting at Central Piedmont. That grew into a full-time instructor role, and then into Department Chair in 2025. From there I returned to Wingate — my alma mater — as adjunct in the Honors program, this time to co-teach applied AI.</p>
    <p>Along the way: I led a 12-person content team at VMware responsible for sixteen courses across vSphere, VMware Cloud, and HCX — work that drove $40M in customer revenue in 2022. I modernized the team's process from ADDIE to a SAM-based, agile approach suited to the pace of SaaS. As senior instructor, I led the Carbon Black and VMware on AWS portfolio with a global instructor rating consistently above 4.95.</p>
    <p>Today I chair an IT department at Central Piedmont spanning three program areas:</p>
    <ul class="pathways">
      <li><strong>Cybersecurity</strong> — AAS and certificate programs covering security fundamentals, network defense, ethical hacking, and incident response. Industry alignment with Palo Alto Networks and CompTIA Security+.</li>
      <li><strong>Cloud &amp; Networking</strong> — Cisco-aligned networking through CCNA, plus AWS, Azure, and Red Hat Linux. Students work in a live on-campus data center as part of the curriculum.</li>
      <li><strong>IT Support</strong> — Help desk, end-user computing, hardware, and operating systems. CompTIA A+ and ITIL-aligned, with stackable credentials into Cybersecurity or Cloud &amp; Networking.</li>
    </ul>
    <p>Across all three I've built employer collaborations with Red Hat and Palo Alto Networks, redesigned entry-level courses around AI-augmented work, and mentored student data-center workers connecting classroom content to live infrastructure.</p>
    <p class="thesis">My research focus: <HighlightPhrase text="how AI is reshaping entry-level IT work, and what post-secondary CTE has to do about it." phrase="entry-level IT work" /></p>
  </section>

  <section class="container section">
    <h2>Career history</h2>
    <ul class="career">
      {career.map((c) => (
        <li>
          <span class="years">{c.data.years}</span>
          <span class="title">{c.data.title}</span>
          <span class="org">{c.data.org}</span>
        </li>
      ))}
    </ul>
  </section>

  <section class="container section">
    <h2>Education</h2>
    <ul class="edu">
      {education.map((e) => (
        <li>
          <span class="years">{e.date}</span>
          <span class="title">{e.deg}{e.honors && <em class="honors"> · {e.honors}</em>}</span>
          <span class="org">{e.inst}</span>
        </li>
      ))}
    </ul>
  </section>

  <section class="container section">
    <h2>Certifications</h2>
    <ul class="bullets">
      {certifications.map((c) => <li>{c}</li>)}
    </ul>
  </section>

  <section class="container section">
    <h2>Honors &amp; Awards</h2>
    <ul class="bullets">
      {awards.map((a) => <li>{a}</li>)}
    </ul>
  </section>

  <section class="container section last">
    <h2>Service &amp; Leadership</h2>
    <ul class="service">
      {service.map((s) => (
        <li>
          <span class="years">{s.years}</span>
          <span class="body">{s.body}</span>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>

<style>
  .container { max-width: var(--container-max); margin: 0 auto; padding-left: var(--space-page-x); padding-right: var(--space-page-x); }
  .page-header { padding: 70px 0 50px; border-bottom: 2px solid var(--ink); }
  .hdr { display: grid; grid-template-columns: 1.4fr 1fr; gap: 50px; align-items: center; }
  .kicker { font-size: 11px; letter-spacing: .15em; text-transform: uppercase; font-weight: 800; background: var(--ink); color: var(--page); padding: 4px 10px; border-radius: 4px; }
  h1 { font-size: 60px; line-height: 1; margin: 18px 0 18px; font-weight: 800; letter-spacing: -.035em; }
  .lede { font-size: 17px; line-height: 1.55; color: var(--ink-2); margin-bottom: 22px; }
  .cv-row { display: flex; gap: 10px; flex-wrap: wrap; }
  .cv-btn { padding: 11px 18px; border-radius: var(--radius-pill); font-size: 13px; font-weight: 700; display: inline-block; }
  .cv-btn.primary { background: var(--ink); color: var(--page); }
  .cv-btn.ghost { background: transparent; border: 2px solid var(--ink); color: var(--ink); padding: 9px 16px; }
  .photo img { border-radius: var(--radius-lg); border: 2.5px solid var(--ink); box-shadow: var(--shadow-card); width: 100%; height: auto; }

  .section { padding: 50px 0 0; }
  .section.last { padding-bottom: 80px; }
  .section h2 { font-size: 28px; font-weight: 800; margin: 0 0 18px; letter-spacing: -.02em; }
  .section p { font-size: 16px; line-height: 1.65; color: var(--ink-2); margin-bottom: 14px; max-width: 75ch; }
  .thesis { font-size: 18px; font-weight: 600; padding: 18px; background: var(--card); border: 2px solid var(--accent); border-radius: var(--radius-lg); margin-top: 18px; }
  .pathways { list-style: none; display: grid; gap: 14px; margin: 14px 0 18px; padding: 0; }
  .pathways li {
    background: var(--card);
    border: 2px solid var(--ink);
    border-radius: var(--radius-lg);
    padding: 16px 20px;
    font-size: 15px;
    line-height: 1.55;
    color: var(--ink-2);
    border-left: 6px solid var(--accent);
  }
  .pathways strong { color: var(--ink); font-weight: 800; font-size: 15px; }

  .career, .edu { list-style: none; display: grid; gap: 6px; }
  .career li, .edu li { display: grid; grid-template-columns: 130px 1fr 1fr; gap: 18px; padding: 10px 0; border-bottom: 1px dashed #c8c4be; font-size: 14px; }
  .years { font-weight: 800; }
  .title { font-weight: 600; }
  .title .honors { color: var(--accent); font-weight: 700; font-style: normal; }
  .org { color: var(--muted); }

  .bullets { padding-left: 22px; }
  .bullets li { font-size: 15px; line-height: 1.65; color: var(--ink-2); margin-bottom: 6px; }

  .service { list-style: none; display: grid; gap: 6px; padding: 0; }
  .service li { display: grid; grid-template-columns: 160px 1fr; gap: 18px; padding: 10px 0; border-bottom: 1px dashed #c8c4be; font-size: 14px; }
  .service .body { color: var(--ink-2); line-height: 1.5; }

  @media (max-width: 860px) {
    .hdr { grid-template-columns: 1fr; }
    h1 { font-size: 40px; }
    .career li, .edu li, .service li { grid-template-columns: 1fr; gap: 2px; padding-bottom: 12px; }
  }
</style>
