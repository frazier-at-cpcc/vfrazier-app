---
// Buttondown free tier — sign up at buttondown.email and replace USERNAME below
// with the chosen handle. Until set up, submissions 404 silently.
const BUTTONDOWN_USERNAME = 'vfrazier';
const action = `https://buttondown.com/api/emails/embed-subscribe/${BUTTONDOWN_USERNAME}`;
---
<section class="subscribe">
  <div class="inner">
    <span class="kicker"><i class="fa-solid fa-envelope" aria-hidden="true"></i> Subscribe</span>
    <h2>Get new writing in your inbox.</h2>
    <p class="lede">About one post a month — research notes, classroom field reports, and what's working (or not) in AI + community-college IT education. No spam. Easy unsubscribe.</p>
    <form action={action} method="post" target="_blank" rel="noopener" class="form">
      <label class="visually-hidden" for="bd-email">Email address</label>
      <input
        type="email"
        name="email"
        id="bd-email"
        required
        autocomplete="email"
        placeholder="you@example.com"
      />
      <button type="submit">Subscribe →</button>
    </form>
    <p class="alt">Prefer RSS? <a href="/rss.xml">Subscribe via RSS</a> — same posts, no inbox.</p>
  </div>
</section>

<style>
  .subscribe {
    padding: var(--space-section) 0;
    border-top: 2px solid var(--ink);
    background: var(--accent-soft);
  }
  .inner {
    max-width: 640px;
    margin: 0 auto;
    padding: 0 var(--space-page-x);
    text-align: center;
  }
  .kicker {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 11px;
    letter-spacing: .14em;
    text-transform: uppercase;
    font-weight: 800;
    color: var(--accent);
    background: var(--card);
    border: 1.5px solid var(--accent);
    padding: 5px 12px;
    border-radius: var(--radius-pill);
  }
  .kicker i { font-size: 12px; }
  h2 {
    font-size: 32px;
    font-weight: 800;
    letter-spacing: -.025em;
    margin: 18px 0 10px;
    line-height: 1.1;
  }
  .lede {
    font-size: 15px;
    line-height: 1.55;
    color: var(--ink-2);
    margin-bottom: 22px;
    max-width: 56ch;
    margin-left: auto;
    margin-right: auto;
  }
  .form {
    display: flex;
    gap: 8px;
    max-width: 460px;
    margin: 0 auto 14px;
  }
  .form input {
    flex: 1;
    border: 2px solid var(--ink);
    border-radius: var(--radius-sm);
    padding: 12px 14px;
    font-size: 14px;
    background: var(--card);
    font-weight: 500;
  }
  .form button {
    background: var(--ink);
    color: var(--page);
    border: 2px solid var(--ink);
    padding: 12px 20px;
    border-radius: var(--radius-sm);
    font-weight: 700;
    font-size: 14px;
    white-space: nowrap;
    cursor: pointer;
    transition: transform .12s, box-shadow .12s;
  }
  .form button:hover { transform: translate(-1px, -1px); box-shadow: 3px 3px 0 var(--accent); }
  .alt { font-size: 12px; color: var(--muted); margin: 0; }
  .alt a { color: var(--accent); text-decoration: underline; font-weight: 600; }
  .visually-hidden {
    position: absolute;
    clip: rect(0 0 0 0);
    width: 1px;
    height: 1px;
    overflow: hidden;
  }
  @media (max-width: 720px) {
    h2 { font-size: 26px; }
    .form { flex-direction: column; }
    .form button { width: 100%; }
  }
</style>
